HOST=0.0.0.0
PORT=3000
PRIVATE_PORT=3099
LNURL_DOMAIN=localhost
POSTGRES_URL=postgres://postgres:postgres@localhost:5432/noah
POSTGRES_MAX_CONNECTIONS=10
REDIS_URL=redis://127.0.0.1:6379
EXPO_ACCESS_TOKEN=your-expo-access-token
ARK_SERVER_URL=http://localhost:3535
SERVER_NETWORK=regtest
BACKUP_CRON="every 2 hours"
S3_BUCKET_NAME=noah-regtest-backups
MINIMUM_APP_VERSION=0.0.1

# AWS credentials for S3
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-2

# Email and auth
EMAIL_DEV_MODE=true
AUTH_JWT_SECRET=dont_use_this_in_production

# Zoho Desk support tickets
ZOHO_CLIENT_ID=your-zoho-client-id
ZOHO_CLIENT_SECRET=your-zoho-client-secret
ZOHO_REFRESH_TOKEN=your-zoho-refresh-token
ZOHO_ORG_ID=your-zoho-org-id
ZOHO_DEPARTMENT_ID=your-zoho-department-id
ZOHO_ACCOUNTS_URL=https://accounts.zoho.com
ZOHO_API_DOMAIN=https://desk.zoho.com
ZOHO_AGENT_TICKET_BASE_URL=https://desk.zoho.com/agent/noahsupport/noah/tickets/details

# Telegram support ticket notifications
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_SUPPORT_CHAT_ID=your-telegram-chat-id
TELEGRAM_SUPPORT_MESSAGE_THREAD_ID=your-telegram-topic-id
